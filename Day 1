//Program 1
//Program to convert celcius to fahrenhit
#include<iostream>
using namespace std;
int main(){
    double celcius;
    double fahrenhit;
    cin>>celcius;
    fahrenhit=(celcius*9.0/5.0)+32;
    cout<<fahrenhit<<endl;
    return 0;
}


