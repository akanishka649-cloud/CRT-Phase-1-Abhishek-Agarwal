//Program 5
//Print a hollow square
#include<iostream>
using namespace std;
int main(){
    for(int i=1;i<=5;i++){
        for(int j=1;j<=5;j++){
            if(i==1||i==5||j==1||j==5){
                cout<<"*";
            }else{
                cout<<" ";
            }
        }
        cout<<"\n";
    }
}



//Program 6
//Print a reverse right angled triangle 

#include<iostream>
using namespace std;
int main(){
    
    int n;
    cin>>n; 
    for(int i=1;i<=5;i++){
        for(int j=n-i;j>=1;j--){
            cout<<" ";
        } for(int k=1;k<=i;k++){
            cout<<"*";
        }
        cout<<"\n";
    }
}

