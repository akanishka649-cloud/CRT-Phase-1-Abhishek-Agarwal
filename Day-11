// Binary Search
#include<iostream>
using namespace std;
int main(){
    int n;
    cout<<"enter a size of an array...";
    cin>>n;
    int arr[n];
    cout<<"enter a sorted array...";
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    int target;
    cout<<"enter the target element...";
    cin>>target;
    //Binary search code
    int low=0;
    int high =n-1;
    bool found=false;
    while(low==high){
        int mid=(low+high)/2;
        if(arr[mid]==target){
            cout<<"element found at index"<<mid;
        }else if(arr[mid]<target){
            low=mid+1;
        }else{
            high=mid-1;
        }
    }
    if(found==false){
        cout<<"elements not found...";
    }
    return 0;
}

























