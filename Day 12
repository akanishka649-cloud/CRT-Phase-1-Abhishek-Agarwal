#include<iostream>
using namespace std;
void printNumber(int n){
    //base condition
    if(n>5){
        return ;
    }
    //logic
    cout<<n<<" " ;
    printNumber(n+1);
}
int main(){
    printNumber(1);
}







//Program 2
//Factorial of a number
//Uing Recrussion
#include<iostream>
using namespace std;
int fact(int n){
    //BASE  CONDITION
    if(n==0||n==1)
    return 1;
    //LOGIC
    return n*fact(n-1);
}
int main(){
    cout<<fact(5);
    return 0;
}






