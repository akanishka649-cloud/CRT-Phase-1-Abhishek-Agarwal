//Program--5 
//Swapping of two numbers pointers and functions

#include<iostream>
using namespace std;

void swapNumber(int *ptr1 , int *ptr2) {
    int temp=*ptr1;
     *ptr1=*ptr2; 
    *ptr2=temp;
}

int main() {
    int a, b;
    cin >> a;
    cin >> b;
    swapNumber(&a, &b);
    cout << a << " " << b;
}







