//Program 1
//STACK
//Reversed the given Array
#include<iostream>
#include<stack>
using namespace std;
int main(){
    int arr[]={10,20,30,40,50};
    int n=5;
    stack<int>st;
    //Jva --Stack<Integer> st=new Stack<>();
    //push the data into the stack
    for(int i=0;i<n;i++){
        st.push(arr[i]);
    }
    //pop out the top most data from the stack and put into the array
    for(int i=0;i<n;i++){
        arr[i]=st.top();
        st.pop();
    }
    cout<<"Reversed Array...";
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
    return 0;
}






//Program 2
//Reverse an Array using STACK
//LeetCode 344
class Solution {
public:
     void reverseString(vector<char>& s){
        stack<char> st;
        
        for(int i=0;i<s.size();i++){
            st.push(s[i]);
        }
        int i=0;
        while(!st.empty()){
            s[i++]=st.top();
            st.pop();
        }  
     }   
};








//Program 3
//Valid Parantheses using STACK
//LeetCode 20
class Solution {
public:
    bool isValid(string s) {
        stack<char>st;
        for(char c:s){
           if(c=='(') 
           st.push(')');
            else if(c=='[')
            st.push(']');
            else if(c=='{')
            st.push('}');
            else{
                if(st.empty()||st.top()!=c){
                    return false;
                }st.pop();
            }
        }
        return st.empty();
    }
};






//Program 4
//Nearest Greatest Number
//STACK
class Solution {
public:
    vector<int> nextGreaterElement(vector<int>& nums1, vector<int>& nums2) {
        //code here
        int n=arr.size();
        stack<int>st;
        vector<int>nge(n);
        for(int i=1;i>=0;i--){
            while(!st.empty() && st.top()<=arr[i]){
                st.pop();
            }
            if(st.empty()){
                nge[i]=-1;
            }else{
                nge[i]=st.top();
            }
            st.push(arr[i]);
        }
        return nge;
    }
};
