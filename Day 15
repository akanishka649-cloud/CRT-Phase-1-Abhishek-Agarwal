//Program 1
//STACK
//Reversed the given Array
#include<iostream>
#include<stack>
using namespace std;
int main(){
    int arr[]={10,20,30,40,50};
    int n=5;
    stack<int>st;
    //Jva --Stack<Integer> st=new Stack<>();
    //push the data into the stack
    for(int i=0;i<n;i++){
        st.push(arr[i]);
    }
    //pop out the top most data from the stack and put into the array
    for(int i=0;i<n;i++){
        arr[i]=st.top();
        st.pop();
    }
    cout<<"Reversed Array...";
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
    return 0;
}





