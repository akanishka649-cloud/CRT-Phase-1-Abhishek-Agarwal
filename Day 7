//Program 1
//call by refrence and call by value
#include<iostream>
using namespace std;
void updatebyValue(int a){
    a=500;
}
   void updatebyReference(int &a){
        a=500;
    }

int main(){
    int original=100;
    updatebyValue(original);
   cout<< original<<"\n";
   updatebyReference(original);
    cout<<original;
}



